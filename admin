  const filter = document.getElementById('driver-filter').value;
  let q = `drivers?tenant_id=eq.${TENANT_ID}&order=created_at.desc&limit=100&select=id,full_name,phone,wechat_id,status,is_active,vehicle_type,points,created_at`;
  if (filter !== '') q += `&is_active=eq.${filter}`;

  const tbody = document.getElementById('drivers-body');
  tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:30px;">加载中...</td></tr>';

  try {
    const [drivers, trips] = await Promise.all([
      supaFetch(q),
      supaFetch(`trips?tenant_id=eq.${TENANT_ID}&status=eq.completed&select=driver_id`)
