// ── Suppliers ──
function supplierBadge(status) {
  const map = {
    new: ['badge-pending-driver', '⏳ 待审核'],
    pending: ['badge-pending-driver', '⏳ 待审核'],
    approved: ['badge-active', '✅ 已通过'],
    rejected: ['badge-cancelled', '✕ 已驳回']
  };
  const [cls, label] = map[status] || ['badge-inactive', status || '未知'];
  return `<span class="badge ${cls}">${label}</span>`;
}

function supplierServiceText(lead) {
  const fields = lead.fields || {};
  if(lead.channel==='adoption'||lead.need_type==='adoption')return 'AI 领养';
  if(lead.channel==='wish_wall'||String(lead.need_type||'').startsWith('wish_wall'))return '心愿墙';
  if(lead.channel==='feedback'||lead.need_type==='feedback')return '反馈/吐槽';
  return fields.service_type || lead.need_type || (lead.message || '').split('\n')[0].replace('服务类型：','') || '-';
}

function supplierQualificationText(lead) {
  const fields = lead.fields || {};
  const license = fields.license || '未填写资质';
  const url = fields.public_verification_url || '';
  return url ? `${license} · ${url}` : license;
}

async function loadSuppliers() {
  const filter = document.getElementById('supplier-filter').value;
  let q = `beta_leads?order=created_at.desc&limit=100`;
  if (filter) q += `&status=eq.${filter}`;

  const tbody = document.getElementById('suppliers-body');
  tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:30px;">加载中...</td></tr>';

  try {
    let leadTable = 'beta_leads';
    let leads = [];
    try {
      leads = await supaFetch(q);
    } catch(primaryError) {
      leadTable = 'user_leads';
      let fallbackQ = `user_leads?order=created_at.desc&limit=100`;
      if (filter) fallbackQ += `&status=eq.${filter}`;
      leads = await supaFetch(fallbackQ);
    }
    if (!leads.length) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text3);padding:40px;">暂无公测线索</td></tr>';
      return;
    }
    tbody.innerHTML = leads.map(lead => {
      const status = lead.status || 'new';
      const service = supplierServiceText(lead);
      const qualification = supplierQualificationText(lead);
      const message = (lead.message || '').replace(/\n/g, ' · ');
      const isSupply = lead.lead_type === 'supply';
      return `<tr>
        <td>
          <div style="font-weight:700;">${escapeHtml(lead.name || '华伴用户')}</div>
          <div style="font-size:11px;color:var(--text3);">${escapeHtml(lead.channel || 'profile')}</div>
        </td>
        <td>
          <div style="font-size:13px;color:var(--text);">${escapeHtml(lead.city || '-')}</div>
          <div style="font-size:11px;color:var(--text3);">${escapeHtml(lead.country || '')}</div>
        </td>
        <td>
          <div style="font-weight:700;color:var(--accent);">${escapeHtml(service)}</div>
          <div style="font-size:11px;color:var(--gold);max-width:260px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">资质：${escapeHtml(qualification)}</div>
          <div style="font-size:11px;color:var(--text3);max-width:260px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escapeHtml(message)}</div>
        </td>
        <td style="font-family:monospace;font-size:12px;">${escapeHtml(lead.contact || '-')}</td>
        <td>${supplierBadge(status)}</td>
        <td style="font-size:12px;color:var(--text3);">${fmtDateShort(lead.created_at)}</td>
        <td>
          ${isSupply && status !== 'approved' ? `<button class="action-btn success" onclick="approveSupplier('${lead.id}','${leadTable}')">通过</button>` : ''}
          ${isSupply && status !== 'rejected' ? `<button class="action-btn danger" onclick="rejectSupplier('${lead.id}','${leadTable}')" style="margin-left:4px;">驳回</button>` : ''}
          <button class="action-btn" onclick="copyId('${lead.id}')" style="margin-left:4px;">复制ID</button>
        </td>
      </tr>`;
    }).join('');
  } catch(e) {
    tbody.innerHTML = `<tr><td colspan="7" style="color:var(--red);padding:20px;">${escapeHtml(e.message)}</td></tr>`;
  }
}

async function approveSupplier(id, table='beta_leads') {
  if (!confirm('确认已完成必要资质核验，并通过这个供给侧申请？')) return;
  await supaPatch(`${table}?id=eq.${id}`, {
    status: 'approved',
    stage: 'approved',
    next_action: 'open_supplier_hub',
    notes: 'admin_approved_after_qualification_review',
    updated_at: new Date().toISOString()
  });
  alert('✅ 已通过。用户端个人中心将开放供给中心入口。');
  loadSuppliers();
}

async function rejectSupplier(id, table='beta_leads') {
  const notes = prompt('驳回原因/需要补充的资料（可选）：', '');
  await supaPatch(`${table}?id=eq.${id}`, {
    status: 'rejected',
    stage: 'need_more_info',
