        </td>
        <td><span style="font-size:12px;color:var(--text2);">${d.vehicle_type||'-'}</span></td>
        <td>
          ${activeBadge}
          <div style="font-size:11px;color:var(--text3);margin-top:4px;">${statusLabel}</div>
        </td>
        <td style="font-weight:700;color:var(--accent);">${tripCount[d.id]||0}</td>
        <td style="color:var(--purple);font-weight:700;">${d.points||0}</td>
        <td style="font-size:12px;color:var(--text3);">${fmtDateShort(d.created_at)}</td>
        <td>
