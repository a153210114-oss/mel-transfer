        <option value="month">本月</option>
      </select>
      <button class="btn btn-primary" onclick="loadDashboard()">↻ 刷新</button>
    </div>
  </div>

  <div class="content">
    <div class="admin-quick-grid">
      <div class="admin-quick-card" onclick="showSection('suppliers')">
