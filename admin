// ── Finance ──
async function loadFinance() {
  try {
    const thisMonth = new Date();
    thisMonth.setDate(1); thisMonth.setHours(0,0,0,0);
    const monthStart = thisMonth.toISOString();

    const [allCompleted, monthCompleted, drivers] = await Promise.all([
      supaFetch(`trips?tenant_id=eq.${TENANT_ID}&status=eq.completed&select=total_price,driver_id`),
      supaFetch(`trips?tenant_id=eq.${TENANT_ID}&status=eq.completed&completed_at=gte.${monthStart}&select=total_price,driver_id`),
      supaFetch(`drivers?tenant_id=eq.${TENANT_ID}&select=id,full_name`)
    ]);

    const total = allCompleted.reduce((s,t) => s+(parseFloat(t.total_price)||0), 0);
    const monthTotal = monthCompleted.reduce((s,t) => s+(parseFloat(t.total_price)||0), 0);

    document.getElementById('fin-total').textContent = '$' + total.toFixed(0);
    document.getElementById('fin-month').textContent = '$' + monthTotal.toFixed(0);
    document.getElementById('fin-month-count').textContent = monthCompleted.length + ' 单';
    document.getElementById('fin-count').textContent = allCompleted.length;

    // By driver
    const driverMap = {};
    drivers.forEach(d => driverMap[d.id] = d.full_name);

    const byDriver = {};
    allCompleted.forEach(t => {
      if (!t.driver_id) return;
      if (!byDriver[t.driver_id]) byDriver[t.driver_id] = { count: 0, total: 0 };
      byDriver[t.driver_id].count++;
      byDriver[t.driver_id].total += parseFloat(t.total_price)||0;
    });

    const sorted = Object.entries(byDriver).sort((a,b) => b[1].total - a[1].total);

    const tbody = document.getElementById('finance-body');
    tbody.innerHTML = sorted.length ? sorted.map(([id, data]) => `<tr>
      <td style="font-weight:600;">${driverMap[id]||id.slice(0,8)}</td>
      <td style="color:var(--accent);font-weight:700;">${data.count}</td>
      <td style="color:var(--gold);font-weight:700;">$${data.total.toFixed(0)}</td>
      <td style="color:var(--text2);">$${data.count ? (data.total/data.count).toFixed(0) : 0}</td>
    </tr>`).join('') : '<tr><td colspan="4" style="text-align:center;color:var(--text3);padding:40px;">暂无完成订单</td></tr>';

  } catch(e) {
    console.error(e);
  }
}

// Init
window.addEventListener('DOMContentLoaded', () => {
  loadDashboard();
  // Auto refresh every 60s
  setInterval(() => {
    const active = document.querySelector('.section.active')?.id;
    if (active === 'section-dashboard') loadDashboard();
    if (active === 'section-dispatch') loadDispatch();
    if (active === 'section-suppliers') loadSuppliers();
  }, 60000);
});
</script>
</body>
</html>
