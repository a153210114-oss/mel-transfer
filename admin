      </div>
      <div class="stat-card">
        <div class="icon">💰</div>
        <div class="label">今日流水</div>
        <div class="value" id="stat-today-revenue" style="color:var(--gold)">-</div>
        <div class="delta" id="stat-today-revenue-sub">含参考价</div>
