// ── Passengers ──
async function loadPassengers() {
  const tbody = document.getElementById('passengers-body');
  tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text3);padding:30px;">加载中...</td></tr>';
  try {
    const [contacts, trips] = await Promise.all([
