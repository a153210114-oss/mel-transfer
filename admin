<script>
const SUPA_URL = 'https://gxocvpmgfjvmmkkbswgo.supabase.co';
const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd4b2N2cG1nZmp2bW1ra2Jzd2dvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAyNDc4NzAsImV4cCI6MjA5NTgyMzg3MH0.ExUNuOP8YyHQmItY6cdl1Euj7nOXqQq-rQT5-7aNerE';
const TENANT_ID = '00000000-0000-0000-0000-000000000001';

async function supaFetch(path) {
  const res = await fetch(SUPA_URL + '/rest/v1/' + path, {
    headers: {
      'apikey': SUPA_KEY,
      'Authorization': 'Bearer ' + SUPA_KEY,
      'Content-Type': 'application/json'
    }
  });
  if (!res.ok) throw new Error(await res.text());
  return res.json();
}

async function supaPatch(path, data) {
  const res = await fetch(SUPA_URL + '/rest/v1/' + path, {
    method: 'PATCH',
    headers: {
      'apikey': SUPA_KEY,
      'Authorization': 'Bearer ' + SUPA_KEY,
      'Content-Type': 'application/json',
      'Prefer': 'return=representation'
    },
    body: JSON.stringify(data)
  });
  return res.json();
}

// Navigation
function showSection(name) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('section-' + name).classList.add('active');
  const navItem = document.querySelector(`.nav-item[onclick*="'${name}'"]`);
  if (navItem) navItem.classList.add('active');

  const actions = {
    dashboard: loadDashboard,
    trips: loadTrips,
    drivers: loadDrivers,
    passengers: loadPassengers,
    suppliers: loadSuppliers,
    dispatch: loadDispatch,
    'ai-training': loadAITraining,
    finance: loadFinance
  };
  if (actions[name]) actions[name]();
}

// Status badge helper
function statusBadge(status) {
  const map = {
    pending:         ['badge-pending',    '⏳ 待接单'],
    confirmed:       ['badge-confirmed',  '✅ 已确认'],
    driver_en_route: ['badge-enroute',    '🚗 前往中'],
    driver_arrived:  ['badge-arrived',    '📍 已到达'],
    in_progress:     ['badge-inprogress', '🛣️ 行程中'],
    completed:       ['badge-completed',  '✓ 已完成'],
    cancelled:       ['badge-cancelled',  '✕ 已取消'],
  };
  const [cls, label] = map[status] || ['badge-inactive', status];
  return `<span class="badge ${cls}">${label}</span>`;
}

function fmtDate(iso) {
  if (!iso) return '-';
  const d = new Date(iso);
  return d.toLocaleDateString('zh-CN', {month:'2-digit',day:'2-digit'}) + ' ' +
         d.toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit'});
}

function fmtDateShort(iso) {
  if (!iso) return '-';
  return new Date(iso).toLocaleDateString('zh-CN', {month:'2-digit',day:'2-digit'});
}

function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, m => ({
    '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#039;'
  }[m]));
}

const AI_TRAINING_KEY = 'huaban_ai_training_queue';
let selectedTrainingId = null;

function readTrainingItems() {
  try {
    const parsed = JSON.parse(localStorage.getItem(AI_TRAINING_KEY) || '[]');
    return Array.isArray(parsed) ? parsed : [];
  } catch(e) {
    return [];
  }
}

function writeTrainingItems(items) {
  localStorage.setItem(AI_TRAINING_KEY, JSON.stringify(items));
}

function trainingBadge(status) {
  const map = {
    open: ['badge-pending', '待训练'],
    trained: ['badge-completed', '已训练'],
    ignored: ['badge-inactive', '已忽略']
  };
  const [cls, label] = map[status] || map.open;
  return `<span class="badge ${cls}">${label}</span>`;
}

function trainingSourceLabel(source) {
  const map = {
    'chat-error': '文字对话',
    'voice-error': '语音对话',
    'weak-reply': '回答偏弱',
    'more-menu': '未开通入口',
    manual: '手动添加'
  };
  return map[source] || '用户问题';
}

function loadAITraining() {
  const items = readTrainingItems().sort((a,b) => new Date(b.createdAt || 0) - new Date(a.createdAt || 0));
  const today = new Date().toDateString();
  document.getElementById('train-open').textContent = items.filter(i => (i.status || 'open') === 'open').length;
  document.getElementById('train-done').textContent = items.filter(i => i.status === 'trained').length;
  document.getElementById('train-today').textContent = items.filter(i => new Date(i.createdAt || 0).toDateString() === today).length;

  const filter = document.getElementById('training-filter')?.value || 'open';
  const visible = filter === 'all' ? items : items.filter(i => (i.status || 'open') === filter);
  const list = document.getElementById('training-list');
  if (!visible.length) {
    list.innerHTML = '<div class="training-empty">这里暂时没有问题。前台遇到 AI 回答不了、服务异常或未开通能力时，会自动进入这里。</div>';
    if (!items.some(i => i.id === selectedTrainingId)) selectTrainingItem(null);
    return;
  }
  if (!visible.some(i => i.id === selectedTrainingId)) selectedTrainingId = visible[0].id;
  list.innerHTML = visible.map(item => `
    <div class="training-item ${item.id === selectedTrainingId ? 'active' : ''}" onclick="selectTrainingItem('${escapeHtml(item.id)}')">
      <div class="training-question">${escapeHtml(item.question || '未命名问题')}</div>
      <div class="training-meta">
        ${trainingBadge(item.status || 'open')}
        <span>${escapeHtml(trainingSourceLabel(item.source))}</span>
        <span>${fmtDate(item.createdAt)}</span>
      </div>
    </div>
  `).join('');
  selectTrainingItem(selectedTrainingId, false);
}

function selectTrainingItem(id, rerender = true) {
  selectedTrainingId = id;
  const item = readTrainingItems().find(i => i.id === id);
  document.getElementById('training-question-view').textContent = item?.question || '请选择左侧问题';
  document.getElementById('training-answer').value = item?.coachAnswer || '';
  document.getElementById('training-persona').value = item?.personaNote || '';
  document.getElementById('training-selected-status').textContent = item ? ({open:'待训练',trained:'已训练',ignored:'已忽略'}[item.status || 'open'] || '待训练') : '未选择';
  if (rerender) loadAITraining();
}

function addManualTrainingItem() {
  const input = document.getElementById('manual-training-question');
  const question = input?.value.trim();
  if (!question) return;
  const items = readTrainingItems();
  const now = new Date().toISOString();
  const item = {
    id: 'manual-' + Date.now(),
    question,
    context: '教官手动添加',
    source: 'manual',
    status: 'open',
    coachAnswer: '',
    personaNote: '',
    createdAt: now,
    updatedAt: now
  };
  items.unshift(item);
  writeTrainingItems(items);
  if (input) input.value = '';
  selectedTrainingId = item.id;
  document.getElementById('training-filter').value = 'open';
  loadAITraining();
}

function saveTrainingAnswer() {
  if (!selectedTrainingId) return;
  const items = readTrainingItems();
  const item = items.find(i => i.id === selectedTrainingId);
  if (!item) return;
  item.coachAnswer = document.getElementById('training-answer').value.trim();
  item.personaNote = document.getElementById('training-persona').value.trim();
  item.status = 'trained';
  item.updatedAt = new Date().toISOString();
  writeTrainingItems(items);
  document.getElementById('training-filter').value = 'open';
  loadAITraining();
}

function ignoreTrainingItem() {
  if (!selectedTrainingId) return;
  const items = readTrainingItems();
  const item = items.find(i => i.id === selectedTrainingId);
  if (!item) return;
  item.status = 'ignored';
  item.updatedAt = new Date().toISOString();
  writeTrainingItems(items);
  selectedTrainingId = null;
  loadAITraining();
}

async function copyTrainingAnswer() {
  const text = document.getElementById('training-answer').value.trim();
  if (!text) return;
  try {
    await navigator.clipboard.writeText(text);
    document.getElementById('training-selected-status').textContent = '已复制';
  } catch(e) {
    document.getElementById('training-selected-status').textContent = '复制失败';
  }
}

// ── Dashboard ──
async function loadDashboard() {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('dashboard-date').textContent = new Date().toLocaleDateString('zh-CN', {year:'numeric',month:'long',day:'numeric',weekday:'long'});

  try {
    // Parallel fetches
    const [todayTrips, pendingTrips, allDrivers, recentTrips] = await Promise.all([
      supaFetch(`trips?tenant_id=eq.${TENANT_ID}&scheduled_at=gte.${today}T00:00:00&select=id,status,total_price`),
      supaFetch(`trips?tenant_id=eq.${TENANT_ID}&status=eq.pending&scheduled_at=gte.${today}T00:00:00&select=id`),
      supaFetch(`drivers?tenant_id=eq.${TENANT_ID}&select=id,full_name,status,is_active`),
      supaFetch(`trips?tenant_id=eq.${TENANT_ID}&order=created_at.desc&limit=8&select=id,passenger_name,direction,trip_type,total_price,status,scheduled_at,driver_id`)
    ]);

    // Stats
    const completed = todayTrips.filter(t => t.status === 'completed');
    const revenue = todayTrips.reduce((s,t) => s + (parseFloat(t.total_price)||0), 0);
    const onlineDrivers = allDrivers.filter(d => d.is_active && ['at_depot','on_trip'].includes(d.status));

    document.getElementById('stat-today-trips').textContent = todayTrips.length;
    document.getElementById('stat-today-trips-sub').textContent = `${completed.length} 已完成`;
    document.getElementById('stat-today-revenue').textContent = '$' + revenue.toFixed(0);
    document.getElementById('stat-online-drivers').textContent = onlineDrivers.length;
    document.getElementById('stat-online-drivers-sub').textContent = `共 ${allDrivers.filter(d=>d.is_active).length} 位激活司机`;
    document.getElementById('stat-pending-trips').textContent = pendingTrips.length;

    // Recent trips table
    const tbody = document.getElementById('recent-trips-body');
    if (!recentTrips.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--text3);padding:30px;">暂无订单</td></tr>';
    } else {
      tbody.innerHTML = recentTrips.map(t => {
        const dir = t.trip_type==='charter'?'包车':t.direction==='from_airport'?'接机':'送机';
        return `<tr>
          <td><span style="font-family:monospace;font-size:11px;color:var(--text3);">TRP-${t.id.slice(-6).toUpperCase()}</span></td>
          <td>${t.passenger_name||'-'}</td>
          <td><span class="tag">${dir}</span></td>
          <td style="color:var(--gold);font-weight:700;">$${t.total_price||'-'}</td>
          <td>${statusBadge(t.status)}</td>
        </tr>`;
      }).join('');
    }

    // Driver status panel
    const panel = document.getElementById('driver-status-panel');
    const groups = {
      at_depot: allDrivers.filter(d => d.status === 'at_depot' && d.is_active),
      on_trip: allDrivers.filter(d => d.status === 'on_trip' && d.is_active),
      offline: allDrivers.filter(d => (!d.is_active || d.status === 'offline')),
      pending: allDrivers.filter(d => !d.is_active),
    };
    panel.innerHTML = `
      <div class="metric-bar">
        <div class="metric-label"><span class="name">🟢 候单中</span><span class="val">${groups.at_depot.length}</span></div>
        <div class="bar-track"><div class="bar-fill" style="width:${allDrivers.length?groups.at_depot.length/allDrivers.length*100:0}%;background:var(--green);"></div></div>
      </div>
      <div class="metric-bar">
        <div class="metric-label"><span class="name">🚗 行程中</span><span class="val">${groups.on_trip.length}</span></div>
        <div class="bar-track"><div class="bar-fill" style="width:${allDrivers.length?groups.on_trip.length/allDrivers.length*100:0}%;background:var(--accent);"></div></div>
      </div>
      <div class="metric-bar">
        <div class="metric-label"><span class="name">⏳ 待审核</span><span class="val">${groups.pending.length}</span></div>
        <div class="bar-track"><div class="bar-fill" style="width:${allDrivers.length?groups.pending.length/allDrivers.length*100:0}%;background:var(--gold);"></div></div>
      </div>
      <div style="margin-top:8px;">
        ${groups.at_depot.slice(0,3).map(d=>`<div style="font-size:12px;color:var(--text2);padding:3px 0;">🟢 ${d.full_name}</div>`).join('')}
        ${groups.on_trip.slice(0,3).map(d=>`<div style="font-size:12px;color:var(--accent);padding:3px 0;">🚗 ${d.full_name}</div>`).join('')}
      </div>
    `;

    // Activity feed
    const feed = document.getElementById('activity-feed');
    const activities = recentTrips.slice(0,5).map(t => {
      const dir = t.trip_type==='charter'?'包车':t.direction==='from_airport'?'接机':'送机';
      const colors = {pending:'var(--gold)',confirmed:'var(--accent)',completed:'var(--green)',cancelled:'var(--red)',in_progress:'var(--purple)'};
      return {
        color: colors[t.status] || 'var(--text3)',
        text: `<strong>${t.passenger_name||'乘客'}</strong> 预约${dir} · ${statusBadge(t.status)}`,
        time: fmtDate(t.scheduled_at)
      };
    });
    feed.innerHTML = activities.map(a => `
      <div class="activity-item">
        <div class="activity-dot" style="background:${a.color};"></div>
        <div>
          <div class="activity-text">${a.text}</div>
          <div class="activity-time">${a.time}</div>
        </div>
      </div>
    `).join('') || '<div style="color:var(--text3);font-size:13px;">暂无动态</div>';

  } catch(e) {
    console.error(e);
  }
}

// ── Trips ──
async function loadTrips() {
  const statusFilter = document.getElementById('trip-status-filter').value;
  let q = `trips?tenant_id=eq.${TENANT_ID}&order=created_at.desc&limit=50&select=id,passenger_name,passenger_phone,direction,trip_type,scheduled_at,total_price,status,vehicle_type,driver_id,pickup_address,dropoff_address`;
  if (statusFilter) q += `&status=eq.${statusFilter}`;

  const tbody = document.getElementById('trips-body');
  tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--text3);padding:30px;">加载中...</td></tr>';

  try {
    const [trips, drivers] = await Promise.all([
      supaFetch(q),
      supaFetch(`drivers?tenant_id=eq.${TENANT_ID}&select=id,full_name`)
    ]);

    const driverMap = {};
    drivers.forEach(d => driverMap[d.id] = d.full_name);

    if (!trips.length) {
      tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;color:var(--text3);padding:40px;">暂无订单</td></tr>';
      return;
    }

    tbody.innerHTML = trips.map(t => {
      const dir = t.trip_type==='charter'?'包车':t.direction==='from_airport'?'接机':'送机';
      const driverName = t.driver_id ? (driverMap[t.driver_id] || t.driver_id.slice(0,8)) : '<span style="color:var(--text3)">未分配</span>';
      const route = `<div style="font-size:11px;color:var(--text3);max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${t.pickup_address||''}→${t.dropoff_address||''}</div>`;
      return `<tr>
        <td><span style="font-family:monospace;font-size:11px;color:var(--text3);">TRP-${t.id.slice(-6).toUpperCase()}</span></td>
        <td><div style="font-size:13px;font-weight:600;">${fmtDate(t.scheduled_at)}</div></td>
        <td>
          <div style="font-weight:600;">${t.passenger_name||'-'}</div>
          <div style="font-size:11px;color:var(--text3);font-family:monospace;">${t.passenger_phone||''}</div>
        </td>
        <td><span class="tag">${dir}</span>${route}</td>
        <td><span style="font-size:12px;color:var(--text3);">${t.vehicle_type||'-'}</span></td>
        <td style="color:var(--gold);font-weight:700;">$${t.total_price||'-'}</td>
        <td>${driverName}</td>
        <td>${statusBadge(t.status)}</td>
        <td>
          ${t.status === 'pending' ? `<button class="action-btn success" onclick="assignTrip('${t.id}')">分配</button>` : ''}
          ${t.status !== 'cancelled' && t.status !== 'completed' ? `<button class="action-btn danger" onclick="cancelTrip('${t.id}')" style="margin-left:4px;">取消</button>` : ''}
        </td>
      </tr>`;
    }).join('');
  } catch(e) {
    tbody.innerHTML = `<tr><td colspan="9" style="text-align:center;color:var(--red);padding:30px;">${e.message}</td></tr>`;
  }
}

async function cancelTrip(id) {
  if (!confirm('确认取消此订单？')) return;
  await supaPatch(`trips?id=eq.${id}`, {status: 'cancelled'});
  loadTrips();
}

async function assignTrip(tripId) {
  const driverIdInput = prompt('输入司机ID（从司机管理页复制）：');
  if (!driverIdInput) return;
  await supaPatch(`trips?id=eq.${tripId}`, {status:'confirmed', driver_id: driverIdInput});
  loadTrips();
}

// ── Drivers ──
