<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>我的后台 · 华伴</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg: #0a0f1a;
  --surface: #111827;
  --surface2: #1a2235;
  --border: #1e2d45;
  --accent: #00d4ff;
  --green: #00c896;
  --gold: #f5a623;
  --red: #ff4d6d;
  --orange: #ff8c42;
  --purple: #a855f7;
  --text: #e8f0fe;
  --text2: #7a9cc4;
  --text3: #3d5a80;
}
body {
  font-family: 'SF Pro Display', -apple-system, 'Noto Sans SC', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* Layout */
.layout { display: flex; min-height: 100vh; }
.sidebar {
  width: 220px; flex-shrink: 0;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  position: fixed; top: 0; left: 0; height: 100vh;
  z-index: 100;
}
.main { margin-left: 220px; flex: 1; display: flex; flex-direction: column; }

/* Sidebar */
.sidebar-logo {
  padding: 20px 16px 16px;
  border-bottom: 1px solid var(--border);
}
.sidebar-logo .logo-title { font-size: 15px; font-weight: 800; color: var(--text); }
.sidebar-logo .logo-sub { font-size: 11px; color: var(--text3); margin-top: 2px; }
.sidebar-logo .logo-icon { font-size: 24px; margin-bottom: 8px; }

.nav-section { padding: 12px 8px 4px; }
.nav-label { font-size: 10px; color: var(--text3); letter-spacing: 0.1em; font-weight: 700; padding: 0 8px; margin-bottom: 4px; text-transform: uppercase; }
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 12px; border-radius: 10px;
  font-size: 13px; font-weight: 500; color: var(--text2);
  cursor: pointer; transition: all 0.15s; margin-bottom: 2px;
}
.nav-item:hover { background: var(--surface2); color: var(--text); }
.nav-item.active { background: rgba(0,212,255,0.12); color: var(--accent); }
.nav-item .nav-icon { font-size: 16px; width: 20px; text-align: center; }

.sidebar-bottom { margin-top: auto; padding: 12px 8px; border-top: 1px solid var(--border); }
.sidebar-driver {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 10px; border-radius: 10px;
  cursor: pointer; transition: background 0.15s;
}
.sidebar-driver:hover { background: var(--surface2); }
.sidebar-driver .avatar { width: 32px; height: 32px; border-radius: 50%; background: rgba(0,212,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 16px; }
.sidebar-driver .name { font-size: 12px; font-weight: 600; color: var(--text); }
.sidebar-driver .role { font-size: 10px; color: var(--text3); }

/* Topbar */
.topbar {
  padding: 16px 24px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  position: sticky; top: 0; z-index: 50;
}
.page-title { font-size: 18px; font-weight: 800; }
.page-sub { font-size: 12px; color: var(--text3); margin-top: 1px; }
.topbar-actions { display: flex; gap: 10px; align-items: center; }
.btn {
  padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 700;
  cursor: pointer; border: none; font-family: inherit; transition: all 0.15s;
}
.btn-primary { background: var(--accent); color: var(--bg); }
.btn-primary:hover { opacity: 0.9; }
.btn-ghost { background: var(--surface2); color: var(--text2); border: 1px solid var(--border); }
.btn-ghost:hover { color: var(--text); border-color: var(--text3); }

/* Content */
.content { padding: 24px; flex: 1; }

/* Stats Grid */
.stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-bottom: 24px; }
.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 20px;
}
.stat-card .label { font-size: 11px; color: var(--text3); letter-spacing: 0.08em; font-weight: 600; text-transform: uppercase; margin-bottom: 12px; }
.stat-card .value { font-size: 32px; font-weight: 800; font-variant-numeric: tabular-nums; margin-bottom: 4px; }
.stat-card .delta { font-size: 12px; color: var(--text3); }
.stat-card .delta.up { color: var(--green); }
.stat-card .delta.down { color: var(--red); }
.stat-card .icon { font-size: 28px; margin-bottom: 10px; }
.admin-quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;}
.admin-quick-card{background:linear-gradient(135deg,rgba(0,212,255,.14),rgba(0,200,150,.07));border:1px solid rgba(0,212,255,.22);border-radius:14px;padding:15px;cursor:pointer;min-height:94px;transition:transform .15s,border-color .15s,background .15s;}
.admin-quick-card:hover{transform:translateY(-1px);border-color:rgba(0,212,255,.46);background:linear-gradient(135deg,rgba(0,212,255,.19),rgba(0,200,150,.1));}
.admin-quick-card .quick-icon{font-size:22px;margin-bottom:9px;}
.admin-quick-card strong{display:block;font-size:14px;color:var(--text);margin-bottom:5px;}
.admin-quick-card span{display:block;font-size:11px;color:var(--text2);line-height:1.45;}

/* Two column layout */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
.three-col { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 24px; }

@media(max-width:760px){
  body{overflow-x:hidden;}
  .layout{display:block;}
  .sidebar{position:relative;width:100%;height:auto;border-right:0;border-bottom:1px solid var(--border);}
  .sidebar-logo{padding:14px 14px 10px;display:flex;align-items:center;gap:10px;}
  .sidebar-logo .logo-icon{margin:0;font-size:22px;}
  .sidebar-logo .logo-title{font-size:17px;}
  .sidebar-logo .logo-sub{font-size:11px;}
  .nav-section{display:flex;gap:8px;overflow-x:auto;padding:8px 10px;}
  .nav-label{display:none;}
  .nav-item{white-space:nowrap;margin:0;padding:9px 11px;font-size:12px;flex-shrink:0;}
  .sidebar-bottom{display:none;}
  .main{margin-left:0;}
  .topbar{position:relative;padding:14px;align-items:flex-start;gap:10px;}
  .topbar-actions{flex-wrap:wrap;justify-content:flex-end;}
  .topbar-actions .input{max-width:46vw;}
  .topbar-actions .btn{padding:8px 12px;}
  .content{padding:14px;}
  .stats-grid,.admin-quick-grid{grid-template-columns:repeat(2,1fr);gap:10px;}
  .admin-quick-card{min-height:104px;padding:14px;}
  .stat-card{padding:14px;border-radius:13px;}
  .stat-card .value{font-size:25px;}
  .three-col,.two-col{grid-template-columns:1fr;}
  .table{min-width:680px;}
  .page-title{font-size:17px;}
  .card{border-radius:13px;}
  .card-header{padding:14px;}
  .card-body{padding:14px;}
  .table th,.table td{padding:12px 14px;}
}

/* Card */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
}
.card-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.card-title { font-size: 14px; font-weight: 700; }
.card-action { font-size: 12px; color: var(--accent); cursor: pointer; }
.card-body { padding: 20px; }

/* Table */
.table { width: 100%; border-collapse: collapse; }
.table th {
  text-align: left; font-size: 11px; color: var(--text3);
  font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
  padding: 10px 16px; border-bottom: 1px solid var(--border);
}
.table td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border);
  font-size: 13px; vertical-align: middle;
}
.table tr:last-child td { border-bottom: none; }
.table tr:hover td { background: rgba(255,255,255,0.02); }

/* Badges */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 10px; border-radius: 20px;
  font-size: 11px; font-weight: 700;
}
.badge-pending { background: rgba(245,166,35,0.15); color: var(--gold); }
.badge-confirmed { background: rgba(0,212,255,0.15); color: var(--accent); }
.badge-enroute { background: rgba(168,85,247,0.15); color: var(--purple); }
.badge-arrived { background: rgba(255,140,66,0.15); color: var(--orange); }
.badge-inprogress { background: rgba(0,200,150,0.12); color: var(--green); }
.badge-completed { background: rgba(0,200,150,0.15); color: var(--green); }
.badge-cancelled { background: rgba(255,77,109,0.12); color: var(--red); }
.badge-active { background: rgba(0,200,150,0.15); color: var(--green); }
.badge-inactive { background: rgba(122,156,196,0.1); color: var(--text3); }
.badge-pending-driver { background: rgba(245,166,35,0.12); color: var(--gold); }

/* Driver row */
.driver-info { display: flex; align-items: center; gap: 10px; }
.driver-avatar { width: 34px; height: 34px; border-radius: 50%; background: rgba(0,212,255,0.12); display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.driver-name { font-size: 13px; font-weight: 600; }
.driver-phone { font-size: 11px; color: var(--text3); margin-top: 1px; font-family: monospace; }

/* Action menu */
.action-btn {
  background: none; border: 1px solid var(--border);
  border-radius: 6px; padding: 5px 10px;
  font-size: 11px; color: var(--text2);
  cursor: pointer; transition: all 0.15s;
}
.action-btn:hover { border-color: var(--accent); color: var(--accent); }
.action-btn.danger:hover { border-color: var(--red); color: var(--red); }
.action-btn.success:hover { border-color: var(--green); color: var(--green); }

/* Map placeholder */
.map-area {
  height: 200px;
  background: var(--surface2);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 8px;
  color: var(--text3); font-size: 13px;
  position: relative; overflow: hidden;
}
.map-area::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at 30% 60%, rgba(0,200,150,0.08) 0%, transparent 60%),
              radial-gradient(ellipse at 70% 30%, rgba(0,212,255,0.06) 0%, transparent 60%);
}

/* Activity feed */
.activity-item {
  display: flex; gap: 12px; align-items: flex-start;
  padding: 12px 0; border-bottom: 1px solid var(--border);
}
.activity-item:last-child { border-bottom: none; }
.activity-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
.activity-text { font-size: 13px; line-height: 1.5; }
.activity-time { font-size: 11px; color: var(--text3); margin-top: 2px; }

/* Metric bar */
.metric-bar { margin-bottom: 14px; }
.metric-label { display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 12px; }
.metric-label .name { color: var(--text2); }
.metric-label .val { color: var(--text); font-weight: 700; }
.bar-track { height: 6px; background: var(--surface2); border-radius: 3px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }

/* Mini chart (CSS bars) */
.mini-chart { display: flex; align-items: flex-end; gap: 4px; height: 60px; }
.mini-bar { flex: 1; border-radius: 3px 3px 0 0; min-width: 8px; transition: opacity 0.2s; cursor: pointer; }
.mini-bar:hover { opacity: 0.75; }

/* Tag */
.tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; background: var(--surface2); color: var(--text3); }

/* Input */
.input {
  background: var(--surface2); border: 1px solid var(--border);
  border-radius: 8px; padding: 9px 12px;
  color: var(--text); font-size: 13px; font-family: inherit;
  outline: none; transition: border-color 0.15s;
}
.input:focus { border-color: var(--accent); }
.input::placeholder { color: var(--text3); }
.textarea {
  width: 100%;
  min-height: 120px;
  resize: vertical;
  line-height: 1.6;
}
.training-layout {
  display: grid;
  grid-template-columns: minmax(320px, 0.9fr) minmax(420px, 1.1fr);
  gap: 16px;
}
.training-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-height: 620px;
  overflow: auto;
  padding: 14px;
}
.training-item {
  border: 1px solid var(--border);
  background: rgba(255,255,255,0.02);
  border-radius: 12px;
  padding: 12px;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
}
.training-item:hover,
.training-item.active {
  border-color: var(--accent);
  background: rgba(0,212,255,0.08);
}
.training-question {
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 8px;
}
.training-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  font-size: 11px;
  color: var(--text3);
}
.training-empty {
  padding: 40px 18px;
  text-align: center;
  color: var(--text3);
  font-size: 13px;
  line-height: 1.7;
}
.coach-field { margin-bottom: 16px; }
.coach-label {
  font-size: 12px;
  color: var(--text2);
  font-weight: 700;
  margin-bottom: 8px;
}
.coach-note {
  font-size: 12px;
  color: var(--text3);
  line-height: 1.7;
  margin-top: 8px;
}

/* Page sections */
.section { display: none; }
.section.active { display: block; }

/* Loading pulse */
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
.loading { animation: pulse 1.5s infinite; }

/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

/* Responsive tweaks */
@media (max-width: 1100px) {
  .stats-grid { grid-template-columns: repeat(2,1fr); }
  .two-col, .three-col, .training-layout { grid-template-columns: 1fr; }
}
</style>
</head>
